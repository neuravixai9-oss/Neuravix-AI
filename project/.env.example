# Скопируй этот файл в .env для локального запуска (на Railway переменные
# задаются в настройках проекта: Project → Variables, .env туда загружать не нужно).

# Токен бота от @BotFather. Обязательно.
BOT_TOKEN=

# Ключ Google AI Studio (Gemini). Обязательно для нейросети, изображений,
# перевода и т.д. Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Твой числовой Telegram ID (узнать у @userinfobot). Обязательно —
# без него никто не получит доступ к админ-панели бота.
OWNER_ID=

# Необязательно: твой username в Telegram без @ — используется в паре
# сообщений ИИ и для отображения владельца.
OWNER_USERNAME=

# Необязательно: username аккаунта поддержки без @ — показывается
# пользователям в разделах "Тарифы"/"Помощь"/"Магазин".
SUPPORT_USERNAME=

# Необязательно: путь к файлу базы данных SQLite. По умолчанию — файл
# neuravix.db рядом с кодом. На Railway без подключённого Volume файловая
# система не сохраняется между деплоями — если это важно, подключи Volume
# и укажи здесь путь внутри него, например /data/neuravix.db.
# DB_PATH=/data/neuravix.db

# Необязательно: путь для бэкапов БД, создаваемых из админ-панели.
# BACKUP_DIR=/data/backups
